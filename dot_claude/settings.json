{
  "awsAuthRefresh": "saml2aws login --force --skip-prompt",
  "model": "global.anthropic.claude-opus-4-6-v1[1m]",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline --style=powerline"
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "hookify@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": true,
    "plugin-dev@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "atlassian@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "autoUpdaterStatus": "disabled",
  "effortLevel": "medium"
}
